    elapsed_ms = round((time.time()-t0)*1000, 1)
    annotated = annotate(frame, detections)
    phones = [d for d in detections if d['class_id'] == PHONE_CLASS_ID]
    return jsonify({'detections': detections, 'phone_count': len(phones),
                    'elapsed_ms': elapsed_ms, 'annotated': to_b64(annotated)})

@app.route('/api/detect/frame', methods=['POST'])
def detect_frame():
    data = request.get_json()
    if not data or 'frame' not in data:
        return jsonify({'error': 'No frame'}), 400
    threshold = float(data.get('threshold', 0.45))
    b64 = data['frame'].split(',')[-1]
    img_bytes = np.frombuffer(base64.b64decode(b64), np.uint8)
    frame = cv2.imdecode(img_bytes, cv2.IMREAD_COLOR)
    if frame is None:
        return jsonify({'error': 'Could not decode frame'}), 400
    detections = detect(frame, threshold,  use_tiling=False)
    annotated = annotate(frame, detections)
    phones = [d for d in detections if d['class_id'] == PHONE_CLASS_ID]
    return jsonify({'detections': detections, 'phone_count': len(phones), 'annotated': to_b64(annotated)})

@app.route('/api/detect/video', methods=['POST'])
def detect_video():
    file = request.files.get('video')
    threshold = float(request.form.get('threshold', 0.45))
    if not file:
        return jsonify({'error': 'No video'}), 400
    save_path = UPLOAD_FOLDER / f'vid_{int(time.time())}.mp4'
    file.save(str(save_path))
    def generate():
        cap = cv2.VideoCapture(str(save_path))
        total = int(cap.get(cv2.CAP_PROP_FRAME_COUNT)) or 1
        idx = 0
        phone_frames = 0
        while True:
            ret, frame = cap.read()
            if not ret:
                break
            idx += 1
            if idx % 3 == 0 or idx == 1:
                detections = detect(frame, threshold)
                annotated = annotate(frame, detections)
                phones = [d for d in detections if d['class_id'] == PHONE_CLASS_ID]
                if phones:
                    phone_frames += 1
            else:
                detections = []
                phones = []
                annotated = frame
            payload = json.dumps({'frame': to_b64(annotated), 'detections': detections,
                                   'phone_count': len(phones), 'progress': round(idx/total*100,1),
                                   'frame_idx': idx, 'total': total})
            yield f'data: {payload}\n\n'
        cap.release()
        save_path.unlink(missing_ok=True)
        yield f'data: {json.dumps({"done": True, "phone_frames": phone_frames, "total_frames": idx})}\n\n'
    return Response(generate(), mimetype='text/event-stream',
                    headers={'Cache-Control': 'no-cache', 'X-Accel-Buffering': 'no'})

