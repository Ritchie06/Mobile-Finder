  if (latency !== null && latency !== undefined) {
    document.getElementById('sLatency').textContent = Math.round(latency);
  }
  const wrap = document.getElementById('detItems');
  wrap.innerHTML = '';
  if (!detections.length) {
    wrap.innerHTML = '<div class="no-det">No objects above threshold.</div>';
    hideAlert(); return;
  }
  detections.forEach(d => {
    const isPhone = d.class_id === 77;
