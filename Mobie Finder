import base64, json, os, time, threading
from pathlib import Path
import cv2
import numpy as np
import tensorflow as tf
from flask import Flask, Response, jsonify, request
from flask_cors import CORS

os.environ['TF_CPP_MIN_LOG_LEVEL'] = '3'

PHONE_CLASS_ID = 77
UPLOAD_FOLDER = Path('uploads')
UPLOAD_FOLDER.mkdir(exist_ok=True)

COCO_LABELS = {
    1:'person', 2:'bicycle', 3:'car', 4:'motorcycle', 44:'bottle',
    47:'cup', 63:'couch', 67:'dining table', 72:'tv', 73:'laptop',
    74:'mouse', 75:'remote', 76:'keyboard', 77:'cell phone',
    84:'book', 85:'clock'
}

print('Loading EfficientDet D1 on GPU...')
model = tf.saved_model.load(str(Path('models/efficientdet_d1/saved_model')))
infer_fn = model.signatures['serving_default']
print('Model ready!')

def iou(box1, box2):
    y1 = max(box1[0], box2[0])
    x1 = max(box1[1], box2[1])
    y2 = min(box1[2], box2[2])
    x2 = min(box1[3], box2[3])
    inter = max(0, y2-y1) * max(0, x2-x1)
    area1 = (box1[2]-box1[0]) * (box1[3]-box1[1])
    area2 = (box2[2]-box2[0]) * (box2[3]-box2[1])
    union = area1 + area2 - inter
    return inter / union if union > 0 else 0

def nms(detections, iou_threshold=0.5):
    if not detections:
        return []
    detections = sorted(detections, key=lambda d: d['score'], reverse=True)
    kept = []
    for det in detections:
        suppress = False
        for k in kept:
            if k['class_id'] == det['class_id'] and iou(det['box'], k['box']) > iou_threshold:
                suppress = True
                break
        if not suppress:
            kept.append(det)
    return kept

def run_inference(frame, threshold, orig_w, orig_h):
    rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
    tensor = tf.convert_to_tensor(rgb[np.newaxis, ...], dtype=tf.uint8)
    out = infer_fn(tensor)
    scores  = out['detection_scores'][0].numpy()
    classes = out['detection_classes'][0].numpy().astype(int)
    boxes   = out['detection_boxes'][0].numpy()
    CONFUSABLE = {75, 44, 47, 76, 74, 84, 85}
    results = []
    for score, cls_id, box in zip(scores, classes, boxes):
        if cls_id == PHONE_CLASS_ID:
            eff = threshold * 0.40
        elif cls_id in CONFUSABLE:
            eff = threshold * 1.35
        else:
            eff = threshold
        if score < eff:
            continue
        if cls_id == PHONE_CLASS_ID:
            y1b, x1b, y2b, x2b = box
            bh, bw = y2b-y1b, x2b-x1b
            if bh == 0 or bw == 0:
                continue
            if bh/bw > 4.0 or bh/bw < 0.3:
                continue
            if (bh*orig_h)*(bw*orig_w) < orig_w*orig_h*0.0005:
                continue
        results.append({
            'class_id': int(cls_id),
            'label': COCO_LABELS.get(int(cls_id), f'class_{cls_id}'),
            'score': round(float(score), 4),
            'box': [round(float(v), 6) for v in box]
        })
    return results

def detect(frame_bgr, threshold=0.45, use_tiling=True):
    lab = cv2.cvtColor(frame_bgr, cv2.COLOR_BGR2LAB)
    l, a, b = cv2.split(lab)
    clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8,8))
    l = clahe.apply(l)
    frame_bgr = cv2.cvtColor(cv2.merge([l,a,b]), cv2.COLOR_LAB2BGR)
    h, w = frame_bgr.shape[:2]
    full = cv2.resize(frame_bgr, (640, 640))
    all_results = run_inference(full, threshold, w, h)
    if not use_tiling:
        return nms(all_results, iou_threshold=0.5)
    tiles = [
        (frame_bgr[0:h//2, 0:w//2],  0,    0),
        (frame_bgr[0:h//2, w//2:w],  w//2, 0),
        (frame_bgr[h//2:h, 0:w//2],  0,    h//2),
        (frame_bgr[h//2:h, w//2:w],  w//2, h//2),
    ]
    for tile, tx, ty in tiles:
        th, tw = tile.shape[:2]
        resized = cv2.resize(tile, (640, 640))
        tile_results = run_inference(resized, threshold, tw, th)
        for r in tile_results:
            y1, x1, y2, x2 = r['box']
            r['box'] = [
                (y1*th+ty)/h, (x1*tw+tx)/w,
                (y2*th+ty)/h, (x2*tw+tx)/w
            ]
        all_results.extend(tile_results)
    return nms(all_results)

def annotate(frame_bgr, detections):
    h, w = frame_bgr.shape[:2]
    out = frame_bgr.copy()
    for det in detections:
        y1, x1, y2, x2 = det['box']
        px1, py1 = int(x1*w), int(y1*h)
        px2, py2 = int(x2*w), int(y2*h)
        is_phone = det['class_id'] == PHONE_CLASS_ID
        conf = f"{det['score']*100:.0f}%"
        if is_phone:
            cv2.rectangle(out,(px1,py1),(px2,py2),(0,220,160),2)
            cs = 14
            for cx,cy,dx,dy in [(px1,py1,1,1),(px2,py1,-1,1),(px1,py2,1,-1),(px2,py2,-1,-1)]:
                cv2.line(out,(cx,cy),(cx+dx*cs,cy),(255,255,255),2)
                cv2.line(out,(cx,cy),(cx,cy+dy*cs),(255,255,255),2)
            tag = f' PHONE {conf} '
            (tw,th),_ = cv2.getTextSize(tag,cv2.FONT_HERSHEY_SIMPLEX,0.52,1)
            cv2.rectangle(out,(px1,py1-th-8),(px1+tw,py1),(0,200,140),-1)
            cv2.putText(out,tag,(px1,py1-4),cv2.FONT_HERSHEY_SIMPLEX,0.52,(0,0,0),1,cv2.LINE_AA)
        else:
            cv2.rectangle(out,(px1,py1),(px2,py2),(100,100,100),1)
            cv2.putText(out,f"{det['label']} {conf}",(px1+2,py1-4),cv2.FONT_HERSHEY_SIMPLEX,0.4,(120,120,120),1,cv2.LINE_AA)
    return out

def to_b64(frame):
    _, buf = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 75])
    return base64.b64encode(buf).decode()

