  if (!camRunning) return;
  videoEl.classList.add('show');
  if (isProcessing) { animId = requestAnimationFrame(camLoop); return; }
  const now2 = Date.now();
  if (now2 - lastDetectionTime < DETECTION_INTERVAL) {
    animId = requestAnimationFrame(camLoop);
    return;
  }
  lastDetectionTime = now2;

  const offscreen = document.createElement('canvas');
  offscreen.width  = videoEl.videoWidth  || 480;
  offscreen.height = videoEl.videoHeight || 360;
